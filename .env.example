NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_APP_URL=
# Server-only Firebase Admin service account JSON (single-line JSON in Vercel).
FIREBASE_SERVICE_ACCOUNT_JSON=
# Server-only HMAC secret for permanent, rotatable table QR links.
QR_SIGNING_SECRET=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Preferred server-only connection for the app. Use the DML-only app_runtime role documented in docs/OPERATIONS.md.
APP_DATABASE_URL=
# Owner-level connection used only for schema migrations and encrypted backups. Never configure this in Preview.
MIGRATION_DATABASE_URL=
# Deprecated compatibility fallback for APP_DATABASE_URL and MIGRATION_DATABASE_URL.
SUPABASE_DATABASE_URL=
RESEND_API_KEY=
EMAIL_FROM=

# Firebase Auth uses popup sign-in to remain compatible with Safari storage partitioning.
# Add every deployed app hostname to Firebase Authentication > Settings > Authorized domains.
